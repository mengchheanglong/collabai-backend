# CollabAI Backend - Environment variable template
# Copy this file to .env.local and fill in real values.

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/collabai"

# JWT
JWT_SECRET="your-secret-key-min-32-characters-long"
JWT_REFRESH_SECRET="your-refresh-secret-key"

# Application
NODE_ENV="development"
PORT=3000

# Redis (token blacklist, account lockout, rate limiting).
# Optional in dev — Redis-backed features fail open if this is unreachable.
REDIS_URL="redis://localhost:6379"

# Email (SMTP) — verification / password-reset code delivery.
# For Gmail, EMAIL_PASS must be a 16-char App Password (Google account → Security →
# 2-Step Verification → App passwords), NOT your normal password.
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="you@example.com"
EMAIL_PASS="your-gmail-app-password"
SMTP_FROM='"Your App" <noreply@example.com>'
